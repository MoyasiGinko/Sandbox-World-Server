# Django core
DJANGO_SECRET_KEY=replace-with-strong-secret
DJANGO_DEBUG=true
DJANGO_ALLOWED_HOSTS=127.0.0.1,localhost,.migetapp.com
# Local dev: db.sqlite3
# Container/release jobs on read-only app filesystems: /tmp/worldserver.sqlite3
DJANGO_DB_PATH=db.sqlite3
DJANGO_DB_FALLBACK_PATH=/tmp/worldserver.sqlite3

# JWT used by auth endpoints
JWT_SECRET=replace-with-strong-jwt-secret
JWT_EXPIRATION_DAYS=7

# Public URLs exposed to clients
PUBLIC_DJANGO_BASE_URL=http://127.0.0.1:8000
PUBLIC_DJANGO_API_BASE_URL=http://127.0.0.1:8000/api
DEFAULT_NODE_API_BASE_URL=http://127.0.0.1:30820/api
DEFAULT_NODE_WS_URL=ws://127.0.0.1:30820
DEFAULT_WORLD_DATABASE_REPO=https://tinybox-worlds.caelan-douglas.workers.dev/
DEFAULT_SERVER_LIST_URL=https://raw.githubusercontent.com/MoyasiGinko/godot-world-release/refs/heads/main/server_list.json
DEFAULT_UPDATE_RELEASE_API_URL=https://api.github.com/repos/caelan-douglas/tinybox/releases/latest
DEFAULT_UPDATE_RELEASE_PAGE_URL=https://github.com/caelan-douglas/tinybox/releases/latest
